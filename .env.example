# Copy this file to `.env` and fill in your key:  cp .env.example .env
# `.env` is gitignored — your real key is never committed.
# Loaded automatically by `npm run dev:api` / `npm run dev:all` (uvicorn --env-file).

# Required. An OpenAI API *platform* key (platform.openai.com, billing enabled —
# NOT a ChatGPT subscription). Every verify call uses it.
OPENAI_API_KEY=

# Optional. Override the vision model (default gpt-5.4-mini).
# EXTRACTION_MODEL=gpt-5.4-mini
