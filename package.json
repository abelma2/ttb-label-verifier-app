{
  "name": "ttb-label-verifier",
  "version": "1.0.0",
  "private": true,
  "description": "Next.js frontend + FastAPI serverless backend for the TTB label verification engine",
  "engines": {
    "node": ">=22.6 <23"
  },
  "scripts": {
    "setup": "pip install -r requirements-dev.txt && npm install",
    "dev": "next dev",
    "dev:api": "uvicorn api.index:app --reload --port 8000 --env-file .env",
    "dev:all": "concurrently -k -n api,web -c blue,green \"npm:dev:api\" \"npm:dev\"",
    "build": "next build",
    "start": "next start",
    "test:api": "pytest tests/test_api.py -q",
    "test:web": "node --experimental-strip-types --test src/lib/__tests__/batch-lib.test.mts src/lib/__tests__/run-batch.test.mts"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
